# ============================================================
# Real Estate Transaction Agent — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ============================================================

# ── Database (PostgreSQL) ────────────────────────────────────
# Used by docker-compose to build the connection string automatically.
# For manual setup, set DATABASE_URL directly (see below).
POSTGRES_USER=reagent
POSTGRES_PASSWORD=changeme_strong_password_here

# Direct connection URL (used if running without docker-compose)
# DATABASE_URL=postgresql+asyncpg://reagent:changeme@localhost:5432/real_estate_agent

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT Auth ─────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_a_32_byte_hex_secret_here
# Token lifetime in minutes (default: 1440 = 24 hours)
# ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Anthropic API ────────────────────────────────────────────
# Required for contract parsing. Get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── SendGrid (email) ─────────────────────────────────────────
# Required for outbound emails. Leave blank to skip email sending.
SENDGRID_API_KEY=SG...
FROM_EMAIL=transactions@yourdomain.com
FROM_NAME=Your Transaction Agent

# ── Twilio (SMS) ─────────────────────────────────────────────
# Required for SMS deadline escalations. Leave blank to skip SMS.
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── File Storage (S3 / Cloudflare R2) ───────────────────────
# Leave blank to use local filesystem storage (development only).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=real-estate-agent-docs
AWS_REGION=us-east-1
# For Cloudflare R2, set this to your R2 endpoint:
# AWS_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com

# ── Logging ──────────────────────────────────────────────────
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR  (default: INFO)
LOG_LEVEL=INFO
# LOG_FORMAT: text | json  (default: text; use json in production)
LOG_FORMAT=text
