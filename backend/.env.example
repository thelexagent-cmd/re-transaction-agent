# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/real_estate_agent

# JWT Auth
SECRET_KEY=your-secret-key-at-least-32-chars-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AWS / Cloudflare R2 Storage
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_BUCKET_NAME=real-estate-agent-docs
AWS_REGION=us-east-1

# Optional: for Cloudflare R2 override endpoint
# AWS_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com

# Anthropic API (required for contract parsing)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Redis (required for Celery task queue + Beat scheduler)
REDIS_URL=redis://localhost:6379/0

# SendGrid (outbound email)
SENDGRID_API_KEY=your-sendgrid-api-key-here
FROM_EMAIL=transactions@lexagent.ai
FROM_NAME=Lex Transaction Agent

# Twilio (outbound SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
