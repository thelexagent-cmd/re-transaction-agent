# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/real_estate_agent

# JWT Auth — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=your-secret-key-at-least-32-chars-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Cloudflare Turnstile CAPTCHA
# Get keys at: https://dash.cloudflare.com/?to=/:account/turnstile
# Test site key (always passes):  1x00000000000000000000AA
# Test secret key (always passes): 1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# AWS / Cloudflare R2 Storage
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_BUCKET_NAME=real-estate-agent-docs
AWS_REGION=auto
# Cloudflare R2 endpoint — uncomment and set your account ID:
# AWS_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com

# Anthropic API (required for contract parsing + document classification)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Redis (required for Celery task queue + Beat scheduler)
REDIS_URL=redis://localhost:6379/0

# Email — Gmail SMTP
# Use a Google App Password (not your real password).
# Enable at: https://myaccount.google.com/apppasswords
GMAIL_USER=the.lex.agent@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
FROM_EMAIL=the.lex.agent@gmail.com
FROM_NAME=Lex Transaction Agent

# Twilio (outbound SMS for deadline / follow-up alerts)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# Market Overview
ZILLOW_RAPIDAPI_KEY=your_rapidapi_key_here
TELEGRAM_BOT_TOKEN=8622735898:AAGZwaEKxvka_eWvpfTY7y5YtN7f89ZjLPk
TELEGRAM_CHAT_ID=your_telegram_user_id
GOOGLE_MAPS_API_KEY=your_google_maps_key
